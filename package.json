{
    "name": "tango",
    "version": "0.0.0",
    "private": true,
    "description": "Typescript Web Framework inspired by Django and DRF!",
    "license": "MIT",
    "author": "Pedro Del Moral Lopez",
    "repository": {
        "type": "git",
        "url": "https://github.com/danceroutine/tango.git"
    },
    "type": "module",
    "scripts": {
        "prelint": "pnpm format",
        "lint": "pnpm run lint:ox && pnpm run lint:eslint && pnpm format:check",
        "lint:ox": "oxlint --format stylish",
        "lint:eslint": "eslint .",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "pnpm run build:test:packages && pnpm run test:root && pnpm -r --filter '!./.temp/**' --if-present run test",
        "test:root": "pnpm exec vitest run --config vitest.config.ts tests/release",
        "test:watch": "pnpm -r --filter '!./.temp/**' --parallel --if-present run test:watch",
        "test:integration": "pnpm run build:test:integration && pnpm run test:integration:run",
        "test:integration:run": "pnpm --filter @danceroutine/tango-migrations test:integration && pnpm --filter @danceroutine/tango-orm test:integration",
        "test:integration:sqlite": "TANGO_TEST_DIALECT=sqlite pnpm test:integration",
        "test:integration:postgres": "TANGO_TEST_DIALECT=postgres TANGO_DB_ADAPTER=postgres TANGO_DATABASE_URL=postgres://postgres:postgres@localhost:5432/tango_test pnpm test:integration",
        "test:integration:all": "bash ./scripts/test-integration-all.sh",
        "test:smoke": "TANGO_RUN_SMOKE=true pnpm build && TANGO_RUN_SMOKE=true pnpm exec vitest run tests/smoke/examples.smoke.test.ts",
        "typecheck": "pnpm run typecheck:prod && pnpm run typecheck:tests && pnpm run typecheck:examples",
        "build:test:packages": "pnpm -r --filter '@danceroutine/*' --filter '!@danceroutine/tango-docs' --filter '!@danceroutine/tango-example-*' --if-present run build",
        "build:test:integration": "pnpm --filter @danceroutine/tango-config build && pnpm --filter @danceroutine/tango-core build && pnpm --filter @danceroutine/tango-schema build && pnpm --filter @danceroutine/tango-resources build && pnpm --filter @danceroutine/tango-testing build && pnpm --filter @danceroutine/tango-codegen build && pnpm --filter @danceroutine/tango-migrations build && pnpm --filter @danceroutine/tango-orm build",
        "build": "pnpm -r --filter '!./.temp/**' --if-present run build",
        "docs:dev": "pnpm --filter @danceroutine/tango-docs dev",
        "docs:build": "pnpm --filter @danceroutine/tango-docs build",
        "docs:preview": "pnpm --filter @danceroutine/tango-docs preview",
        "changeset": "changeset",
        "changeset:version": "pnpm exec tsx scripts/release/version-with-root-changelog.ts",
        "changeset:publish": "pnpm build && changeset publish",
        "typecheck:prod": "tsc --noEmit -p tsconfig.scripts.json && pnpm -r --filter '!./.temp/**' --if-present run typecheck:prod",
        "typecheck:tests": "pnpm -r --filter '!./.temp/**' --if-present run typecheck:test",
        "typecheck:examples": "pnpm -r --filter '@danceroutine/tango-example-*' --if-present run typecheck"
    },
    "devDependencies": {
        "@changesets/cli": "^2.27.10",
        "@danceroutine/tango-config": "workspace:*",
        "@eslint/js": "^10.0.1",
        "@types/eslint": "^9.6.1",
        "@types/node": "^22.9.0",
        "@vitest/coverage-v8": "^4.0.6",
        "eslint": "^9.14.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-oxlint": "^1.25.0",
        "eslint-plugin-prettier": "^5.5.4",
        "globals": "^16.5.0",
        "oxlint": "^1.51.0",
        "oxlint-plugin-eslint": "^1.57.0",
        "oxlint-tsgolint": "^0.15.0",
        "prettier": "^3.6.2",
        "prettier-linter-helpers": "^1.0.0",
        "tsdown": "^0.4.0",
        "tsx": "^4.20.6",
        "typescript": "^5.6.3",
        "typescript-eslint": "^8.46.2",
        "vitest": "^4.0.6"
    },
    "packageManager": "pnpm@9.13.2",
    "engines": {
        "node": ">=22.0.0",
        "pnpm": ">=9.0.0"
    }
}
