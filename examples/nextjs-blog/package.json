{
    "name": "@danceroutine/tango-example-nextjs-blog",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "predev": "sh -c 'if [ \"$TANGO_SKIP_SETUP_SCHEMA\" = \"true\" ]; then exit 0; fi; pnpm run setup:schema'",
        "dev": "next dev",
        "prestart": "sh -c 'if [ \"$TANGO_SKIP_SETUP_SCHEMA\" = \"true\" ]; then exit 0; fi; pnpm run setup:schema'",
        "build": "next build",
        "start": "next start",
        "typecheck": "next typegen && tsc --noEmit",
        "setup:schema": "pnpm exec tango migrate --config ./tango.config.ts",
        "make:migrations": "tango make:migrations --config ./tango.config.ts --models ./src/lib/models.ts",
        "codegen:relations": "pnpm exec tango codegen relations --models ./src/lib/models.ts",
        "prebootstrap": "pnpm run setup:schema",
        "bootstrap": "tsx scripts/bootstrap.ts"
    },
    "dependencies": {
        "@danceroutine/tango-adapters-next": "workspace:*",
        "@danceroutine/tango-cli": "workspace:*",
        "@danceroutine/tango-config": "workspace:*",
        "@danceroutine/tango-core": "workspace:*",
        "@danceroutine/tango-migrations": "workspace:*",
        "@danceroutine/tango-openapi": "workspace:*",
        "@danceroutine/tango-orm": "workspace:*",
        "@danceroutine/tango-resources": "workspace:*",
        "@danceroutine/tango-schema": "workspace:*",
        "better-sqlite3": "^11.7.0",
        "next": "^15.1.6",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "zod": "^4.0.0"
    },
    "devDependencies": {
        "@tailwindcss/typography": "^0.5.16",
        "@types/node": "^22.9.0",
        "@types/react": "^19.0.6",
        "@types/react-dom": "^19.0.2",
        "autoprefixer": "^10.4.21",
        "postcss": "^8.5.6",
        "tailwindcss": "^3.4.17",
        "tsx": "^4.20.6"
    }
}
