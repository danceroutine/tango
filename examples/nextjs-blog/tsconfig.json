{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "composite": false,
        "lib": ["dom", "dom.iterable", "esnext"],
        "jsx": "preserve",
        "incremental": true,
        "plugins": [
            {
                "name": "next"
            }
        ],
        "paths": {
            "@/*": ["./src/*"],
            "@danceroutine/tango-config": ["../../packages/config/src/index.ts"],
            "@danceroutine/tango-config/*": ["../../packages/config/src/*"],
            "@danceroutine/tango-core": ["../../packages/core/src/index.ts"],
            "@danceroutine/tango-core/*": ["../../packages/core/src/*"],
            "@danceroutine/tango-adapters-core": ["../../packages/adapters/core/src/index.ts"],
            "@danceroutine/tango-adapters-core/*": ["../../packages/adapters/core/src/*"],
            "@danceroutine/tango-adapters-next": ["../../packages/adapters/next/src/index.ts"],
            "@danceroutine/tango-adapters-next/*": ["../../packages/adapters/next/src/*"],
            "@danceroutine/tango-migrations": ["../../packages/migrations/src/index.ts"],
            "@danceroutine/tango-migrations/*": ["../../packages/migrations/src/*"],
            "@danceroutine/tango-openapi": ["../../packages/openapi/src/index.ts"],
            "@danceroutine/tango-openapi/*": ["../../packages/openapi/src/*"],
            "@danceroutine/tango-orm": ["../../packages/orm/src/index.ts"],
            "@danceroutine/tango-orm/*": ["../../packages/orm/src/*"],
            "@danceroutine/tango-resources": ["../../packages/resources/src/index.ts"],
            "@danceroutine/tango-resources/*": ["../../packages/resources/src/*"],
            "@danceroutine/tango-schema": ["../../packages/schema/src/index.ts"],
            "@danceroutine/tango-schema/*": ["../../packages/schema/src/*"]
        },
        "allowJs": true,
        "noEmit": true,
        "esModuleInterop": true,
        "resolveJsonModule": true
    },
    "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", "tango.config.ts"],
    "exclude": ["node_modules"]
}
