{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "baseUrl": ".",
        "composite": false,
        "outDir": "./dist",
        "paths": {
            "@danceroutine/tango-core": ["../core/src/index.ts"],
            "@danceroutine/tango-core/*": ["../core/src/*"],
            "@danceroutine/tango-schema": ["../schema/src/index.ts"],
            "@danceroutine/tango-schema/*": ["../schema/src/*"]
        }
    },
    "include": ["src", "package.json"],
    "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"]
}
