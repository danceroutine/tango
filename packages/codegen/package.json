{
    "name": "@danceroutine/tango-codegen",
    "version": "1.10.3",
    "description": "CLI for generating repositories, types, migrations, and OpenAPI specs for Tango",
    "type": "module",
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        },
        "./domain": {
            "types": "./dist/domain/index.d.mts",
            "import": "./dist/domain/index.mjs"
        },
        "./generators": {
            "types": "./dist/generators/index.d.mts",
            "import": "./dist/generators/index.mjs"
        },
        "./frameworks": {
            "types": "./dist/frameworks/index.d.mts",
            "import": "./dist/frameworks/index.mjs"
        },
        "./commands": {
            "types": "./dist/commands/index.d.mts",
            "import": "./dist/commands/index.mjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsdown",
        "test": "vitest run --coverage",
        "test:watch": "vitest",
        "typecheck": "pnpm run typecheck:prod && pnpm run typecheck:test",
        "typecheck:prod": "tsc --noEmit -p tsconfig.json",
        "typecheck:test": "tsc --noEmit -p tsconfig.tests.json"
    },
    "keywords": [
        "tango",
        "codegen",
        "cli",
        "generator",
        "migrations"
    ],
    "author": "Pedro Del Moral Lopez",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/danceroutine/tango.git",
        "directory": "packages/codegen"
    },
    "dependencies": {
        "@danceroutine/tango-core": "workspace:*",
        "@danceroutine/tango-schema": "workspace:*",
        "jiti": "^2.6.1",
        "yargs": "^18.0.0"
    },
    "devDependencies": {
        "@danceroutine/tango-testing": "workspace:*",
        "@types/yargs": "^17.0.33",
        "@types/node": "^22.9.0",
        "tsdown": "^0.22.0",
        "typescript": "^5.6.3",
        "vitest": "^4.0.6",
        "zod": "^4.0.0"
    }
}
