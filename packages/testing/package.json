{
    "name": "@danceroutine/tango-testing",
    "version": "1.10.3",
    "description": "Testing utilities for Tango",
    "type": "module",
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        },
        "./integration": {
            "types": "./dist/integration/index.d.mts",
            "import": "./dist/integration/index.mjs"
        },
        "./vitest": {
            "types": "./dist/vitest/index.d.mts",
            "import": "./dist/vitest/index.mjs"
        },
        "./mocks": {
            "types": "./dist/mocks/index.d.mts",
            "import": "./dist/mocks/index.mjs"
        },
        "./factories": {
            "types": "./dist/factories/index.d.mts",
            "import": "./dist/factories/index.mjs"
        },
        "./assertions": {
            "types": "./dist/assertions/index.d.mts",
            "import": "./dist/assertions/index.mjs"
        },
        "./express": {
            "types": "./dist/express/index.d.mts",
            "import": "./dist/express/index.mjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsdown",
        "test": "vitest run --coverage",
        "test:watch": "vitest",
        "typecheck": "pnpm run typecheck:prod && pnpm run typecheck:test",
        "typecheck:prod": "tsc --noEmit -p tsconfig.json",
        "typecheck:test": "tsc --noEmit -p tsconfig.tests.json"
    },
    "keywords": [
        "tango",
        "testing",
        "test",
        "utilities"
    ],
    "author": "Pedro Del Moral Lopez",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/danceroutine/tango.git",
        "directory": "packages/testing"
    },
    "dependencies": {
        "@danceroutine/tango-config": "workspace:*",
        "@danceroutine/tango-core": "workspace:*",
        "@danceroutine/tango-migrations": "workspace:*",
        "@danceroutine/tango-orm": "workspace:*",
        "@danceroutine/tango-resources": "workspace:*"
    },
    "peerDependencies": {
        "@types/express": "^5.0.0",
        "vitest": "^4.0.0"
    },
    "peerDependenciesMeta": {
        "@types/express": {
            "optional": true
        },
        "vitest": {
            "optional": true
        }
    },
    "devDependencies": {
        "@types/express": "^5.0.0",
        "@types/node": "^22.9.0",
        "tsdown": "^0.22.0",
        "typescript": "^5.6.3",
        "vitest": "^4.0.6",
        "zod": "^4.0.0"
    }
}
