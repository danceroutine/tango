{
    "name": "@danceroutine/tango-schema",
    "version": "1.10.3",
    "description": "Model factory, Zod helpers, and metadata utilities for Tango",
    "type": "module",
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        },
        "./domain": {
            "types": "./dist/domain/index.d.mts",
            "import": "./dist/domain/index.mjs"
        },
        "./model": {
            "types": "./dist/model/index.d.mts",
            "import": "./dist/model/index.mjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsdown",
        "test": "vitest run --coverage",
        "test:watch": "vitest",
        "typecheck": "pnpm run typecheck:prod && pnpm run typecheck:test",
        "typecheck:prod": "tsc --noEmit -p tsconfig.json",
        "typecheck:test": "tsc --noEmit -p tsconfig.tests.json"
    },
    "keywords": [
        "tango",
        "schema",
        "model",
        "zod",
        "validation"
    ],
    "author": "Pedro Del Moral Lopez",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/danceroutine/tango.git",
        "directory": "packages/schema"
    },
    "dependencies": {
        "@danceroutine/tango-core": "workspace:*",
        "zod": "^4.0.0"
    },
    "devDependencies": {
        "@types/node": "^22.9.0",
        "tsdown": "^0.22.0",
        "typescript": "^5.6.3",
        "vitest": "^4.0.6"
    }
}
